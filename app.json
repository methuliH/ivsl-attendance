{
  "expo": {
    "name": "IVSL CPD Event Attendance",
    "slug": "ivsl-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_ivsl.png",
    "userInterfaceStyle": "light",
    "scheme": "ivsl-attendance",
    "splash": {
      "image": "./assets/logo_ivsl.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lk.ivsl.attendance",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan member QR codes for CPD event attendance."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_ivsl.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "lk.ivsl.attendance"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow IVSL Attendance to access your camera to scan member QR codes."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d828feb7-a0c5-441a-aa72-041914d35d22"
      }
    }
  }
}
